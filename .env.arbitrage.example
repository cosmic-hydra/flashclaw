# Example Environment Configuration for FlashClaw Arbitrage Bot

# ============================================
# BLOCKCHAIN CONNECTION
# ============================================

# Ethereum RPC endpoint (Use Alchemy, Infura, or your own node)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY_HERE

# Chain ID (1 = Ethereum Mainnet, 5 = Goerli, 137 = Polygon, etc.)
CHAIN_ID=1

# ============================================
# WALLET CONFIGURATION
# ============================================

# Private key for transaction signing
# ⚠️ CRITICAL: NEVER commit this to git or share it!
# This wallet will execute arbitrage trades
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ============================================
# GAS SETTINGS
# ============================================

# Maximum gas price in wei (100 gwei = 100000000000)
MAX_GAS_PRICE=100000000000

# Gas limit for transactions
GAS_LIMIT=500000

# ============================================
# ARBITRAGE CONFIGURATION
# ============================================

# Minimum profit threshold in wei (0.1 ETH = 100000000000000000)
MIN_PROFIT=100000000000000000

# Scan interval in milliseconds (100ms for high frequency)
SCAN_INTERVAL=100

# Enable/disable the bot
ARBITRAGE_ENABLED=true

# ============================================
# AAVE V3 ADDRESSES (Ethereum Mainnet)
# ============================================

AAVE_POOL_ADDRESS_PROVIDER=0x2f39d218133AFaB8F2B819B1066c7E434Ad94E9e
AAVE_POOL=0x87870Bca3F3fD6335C3F4ce8392D69350B4fA4E2
AAVE_DATA_PROVIDER=0x7B4EB56E7CD4b454BA8ff71E4518426369a138a3
WETH_ADDRESS=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2

# ============================================
# DEX ROUTER ADDRESSES (Ethereum Mainnet)
# ============================================

UNISWAP_V2_ROUTER=0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D
UNISWAP_V2_FACTORY=0x5C69bEe701ef814a2B6a3EDD4B1652CB9cc5aA6f

SUSHISWAP_ROUTER=0xd9e1cE17f2641f24aE83637ab66a2cca9C378B9F
SUSHISWAP_FACTORY=0xC0AEe478e3658e2610c5F7A4A2E1777cE9e4f2Ac

# Add more DEXes as needed
# PANCAKESWAP_ROUTER=...
# BALANCER_VAULT=...

# ============================================
# MONITORING & LOGGING
# ============================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable detailed transaction logging
DETAILED_LOGS=true

# Webhook URL for notifications (optional)
WEBHOOK_URL=

# ============================================
# SAFETY LIMITS
# ============================================

# Maximum number of concurrent transactions
MAX_CONCURRENT_TXN=1

# Maximum daily profit target (in ETH, 0 = unlimited)
DAILY_PROFIT_TARGET=0

# Stop loss - maximum daily loss before auto-stop (in ETH)
MAX_DAILY_LOSS=1

# ============================================
# TESTNET CONFIGURATION (for testing)
# ============================================

# Uncomment these for Goerli testnet testing
# ETH_RPC_URL=https://eth-goerli.g.alchemy.com/v2/YOUR_API_KEY_HERE
# CHAIN_ID=5
# AAVE_POOL=0x... (Goerli addresses)

# ============================================
# NOTES
# ============================================

# 1. Always test on testnet first
# 2. Start with small amounts
# 3. Monitor gas prices continuously
# 4. Keep private keys secure
# 5. Use hardware wallets for production
# 6. Set up alerts for unusual activity
